# ---------------------------------------------------------------------------
# LAIDocs — AI layer configuration (.env)
# Copy to `.env` at the project root. `llm.*` in ~/.laidocs/config.json takes
# precedence over these; these are the seed defaults (see Settings.active_llm).
# ---------------------------------------------------------------------------

# Provider selects the LLM backend. One of:
#   gemini      Google Gemini (hosted; requires API key) — recommended default
#   openai      OpenAI OR any OpenAI-compatible server (Ollama, LM Studio, vLLM)
#   anthropic   Anthropic Claude (chat only — NO embeddings → dense retrieval off)
#   (empty)     resolves to "openai"
DEFAULT_LLM_PROVIDER=gemini

# Chat/completions model id (provider-specific).
#   gemini    e.g. gemini-2.0-flash, gemini-1.5-pro
#   openai    e.g. gpt-4o-mini, or a local model name like llama3.1
#   anthropic e.g. claude-3-5-sonnet-latest
DEFAULT_LLM_MODEL=gemini-2.0-flash

# API key for the hosted provider. Leave blank for a keyless local server.
DEFAULT_LLM_API_KEY=

# Base URL — ONLY used by the openai provider (local/compatible servers).
# Ignored by gemini/anthropic, which use their own endpoints.
#   Ollama     http://localhost:11434/v1
#   LM Studio  http://localhost:1234/v1
DEFAULT_LLM_BASE_URL=

# Embedding model for dense retrieval. Blank → provider default:
#   gemini → models/text-embedding-004 ; openai → text-embedding-3-small
# Anthropic has no embedding backend; dense retrieval is skipped automatically.
DEFAULT_LLM_EMBED_MODEL=

# ---------------------------------------------------------------------------
# Non-AI knobs (kept for completeness; safe to leave at defaults)
# ---------------------------------------------------------------------------
# PORT=8008
# TELEMETRY_ENABLED=true
# TELEMETRY_URL=http://localhost:8001/api/v1/track
